// Para migrar a Supabase/Postgres: cambiar provider a "postgresql" y actualizar DATABASE_URL

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  Usuario
  Administrador
}

enum Priority {
  Alta
  Media
  Baja
}

enum Status {
  Pendiente
  Progreso
  Completada
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  rol           Role           @default(Usuario)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tasks         Task[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model Task {
  id          String   @id @default(cuid())
  title       String
  category    String
  date        String
  priority    Priority
  status      Status
  description String
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("tasks")
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}
